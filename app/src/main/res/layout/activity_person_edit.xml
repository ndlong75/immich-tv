<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f23"
    android:padding="48dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Left: Person photo -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <ImageView
                android:id="@+id/person_image"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:layout_marginBottom="16dp"
                android:contentDescription="Person photo" />

            <Button
                android:id="@+id/btn_set_photo"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Set current photo as thumbnail"
                android:textSize="14sp"
                android:backgroundTint="#6366F1"
                android:textColor="#FFFFFF"
                android:focusable="true"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Right: Edit fields -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit person"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textColor="#93C5FD"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/input_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#1E293B"
                android:textColor="#FFFFFF"
                android:textColorHint="#6B7280"
                android:hint="Person name"
                android:inputType="textPersonName"
                android:textSize="18sp"
                android:paddingHorizontal="16dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:imeOptions="actionNext"
                android:singleLine="true"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Birthday (YYYY-MM-DD)"
                android:textColor="#93C5FD"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/input_birth"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#1E293B"
                android:textColor="#FFFFFF"
                android:textColorHint="#6B7280"
                android:hint="1990-01-15"
                android:inputType="date"
                android:textSize="18sp"
                android:paddingHorizontal="16dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:imeOptions="actionDone"
                android:singleLine="true"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Age will show on photos after setting birthday"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:layout_marginBottom="32dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save"
                android:textSize="18sp"
                android:backgroundTint="#10B981"
                android:textColor="#FFFFFF"
                android:focusable="true"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/text_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="#9CA3AF" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
