<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f23"
    android:padding="48dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:maxWidth="640dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Immich TV Setup"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect to your Immich server"
            android:textColor="#9CA3AF"
            android:textSize="18sp"
            android:layout_marginBottom="40dp" />

        <!-- Server URL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Server URL"
            android:textColor="#93C5FD"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/input_server_url"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1E293B"
            android:textColor="#FFFFFF"
            android:textColorHint="#6B7280"
            android:hint="http://192.168.1.100:2283"
            android:inputType="textUri"
            android:textSize="18sp"
            android:paddingHorizontal="16dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:imeOptions="actionNext"
            android:singleLine="true"
            android:layout_marginBottom="24dp" />

        <!-- API Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API Key"
            android:textColor="#93C5FD"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/input_api_key"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1E293B"
            android:textColor="#FFFFFF"
            android:textColorHint="#6B7280"
            android:hint="Your Immich API key"
            android:inputType="textPassword"
            android:textSize="18sp"
            android:paddingHorizontal="16dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:imeOptions="actionDone"
            android:singleLine="true"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Find your API key in Immich → Account Settings → API Keys"
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btn_test"
                android:layout_width="200dp"
                android:layout_height="56dp"
                android:text="Test Connection"
                android:textSize="16sp"
                android:backgroundTint="#3B82F6"
                android:textColor="#FFFFFF"
                android:focusable="true"
                android:layout_marginEnd="16dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="200dp"
                android:layout_height="56dp"
                android:text="Save &amp; Go Back"
                android:textSize="16sp"
                android:backgroundTint="#10B981"
                android:textColor="#FFFFFF"
                android:focusable="true" />
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="18sp"
            android:textColor="#9CA3AF"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/text_server_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
