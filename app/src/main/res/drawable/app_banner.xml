<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1E40AF"
                android:endColor="#0f0f23"
                android:angle="135" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Icon area -->
    <item
        android:left="24dp"
        android:top="40dp"
        android:right="200dp"
        android:bottom="40dp">
        <shape android:shape="oval">
            <solid android:color="#3B82F6" />
        </shape>
    </item>
    <!-- Text would overlay - but TV launcher handles the label -->
</layer-list>
